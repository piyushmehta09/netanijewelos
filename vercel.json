{
  "functions": {
    "api/*.php": { "runtime": "vercel-php@0.7.1" },
    "client/*.php": { "runtime": "vercel-php@0.7.1" },
    "admin/*.php": { "runtime": "vercel-php@0.7.1" },
    "*.php": { "runtime": "vercel-php@0.7.1" }
  },
  "routes": [
    { "src": "/", "dest": "/client/index.php" },
    { "src": "/admin", "dest": "/admin/index.php" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}