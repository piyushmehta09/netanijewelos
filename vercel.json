{
  "version": 2,
  "builds": [
    { "src": "api/**/*.php", "use": "vercel-php@0.7.1" },
    { "src": "client/**/*.php", "use": "vercel-php@0.7.1" },
    { "src": "admin/**/*.php", "use": "vercel-php@0.7.1" },
    { "src": "*.php", "use": "vercel-php@0.7.1" }
  ],
  "routes": [
    { "src": "/admin/(.*)", "dest": "/admin/$1" },
    { "src": "/admin", "dest": "/admin/index.php" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/client/$1" },
    { "src": "/", "dest": "/client/index.php" }
  ]
}